5:["$","p",null,{"className":"mt-4 text-[#5F6368] leading-relaxed","children":["EhViewer is not directed at children under the age of 13. We do not knowingly collect personal information from children. If you believe a child has provided us with personal information, please"," ",["$","$L12",null,{"href":"/contact","className":"text-[#4586F3] hover:underline","children":"contact us"}]," ","so we can address it."]}]
