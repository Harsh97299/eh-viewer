as long as necessary."]}],["$","h2",null,{"className":"mt-10 text-xl font-semibold text-[#202124]","children":"2. How We Use Information"}],["$","p",null,{"className":"mt-4 text-[#5F6368] leading-relaxed","children":"Server logs are used exclusively to operate and secure the website. We do not use any information to build profiles, serve targeted advertising, or share data with marketing partners."}],["$","h2",null,{"className":"mt-10 text-xl font-semibold text-[#202124]","children":"3. Data Stored on Your Device"}],["$","p",null,{"className":"mt-4 text-[#5F6368] leading-relaxed","children":"All app data — reading history, bookmarks, downloaded files, and settings — is stored locally on your device. Uninstalling EhViewer removes this data. We have no access to it."}],["$","h2",null,{"className":"mt-10 text-xl font-semibold text-[#202124]","children":"4. Third-Party Services"}],["$","p",null,{"className":"mt-4 text-[#5F6368] leading-relaxed","children":"EhViewer connects to content sources that you configure. Those services have their own privacy practices which we do not control. Please review the policies of any source you choose to use."}],["$","p",null,{"className":"mt-4 text-[#5F6368] leading-relaxed","children":["The app's source code, issue tracker, and releases are hosted on"," ",["$","a",null,{"href":"https://github.com/Ehviewer-Overhauled/Ehviewer","className":"text-[#4586F3] hover:underline","target":"_blank","rel":"noopener noreferrer","children":"GitHub"}],", subject to"," ",["$","a",null,{"href":"https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement","className":"text-[#4586F3] hover:underline","target":"_blank","rel":"noopener noreferrer","children":"GitHub's Privacy Statement"}],"."]}],["$","h2",null,{"className":"mt-10 text-xl font-semibold text-[#202124]","children":"5. Cookies & Tracking"}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le"]}]}],"$Lf"],["$L10"],"$L11"]}],"isPartial":false,"sta